<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened runtime (required to notarize). The only resource entitlement warble needs is the
       microphone for dictation; Speech Recognition and Accessibility are granted via TCC prompts,
       not entitlements, for a non-sandboxed app. No get-task-allow (would block notarization). -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
