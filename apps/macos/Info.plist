<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>voz</string>
	<key>CFBundleExecutable</key>
	<string>voz</string>
	<key>CFBundleIconFile</key>
	<string>voz</string>
	<key>CFBundleIdentifier</key>
	<string>io.github.sethmed7.voz</string>
	<key>CFBundleName</key>
	<string>voz</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.6</string>
	<key>CFBundleVersion</key>
	<string>0.1.6</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<key>LSUIElement</key>
	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>voz records only while you hold the dictation hotkey, transcribes it on-device, and never saves the audio.</string>
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Read Aloud with voz</string>
			</dict>
			<key>NSMessage</key>
			<string>readAloud</string>
			<key>NSPortName</key>
			<string>voz</string>
			<key>NSSendTypes</key>
			<array>
				<string>NSStringPboardType</string>
			</array>
		</dict>
	</array>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>voz can fall back to Apple's on-device speech recognizer; recognition stays on your Mac.</string>
	<!-- Sparkle in-app updates. SUFeedURL is read over HTTPS; SUPublicEDKey is the EdDSA public key every
	     downloaded update is verified against (its private half lives only in the maintainer's Keychain).
	     SUEnableAutomaticChecks + a 1-day interval give the quiet background check; the menu item is manual. -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/SethMed7/voz/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>ctuyDA3r2a+kq9gpkkNu9ciA2YEAZ8ImMxIJ9ndtMLc=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
