<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>warble</string>
	<key>CFBundleExecutable</key>
	<string>warble</string>
	<key>CFBundleIconFile</key>
	<string>warble</string>
	<!-- The bundle identifier deliberately keeps the old "voz" name: Sparkle only installs an update
	     whose bundle id matches the running app's, and macOS TCC grants (Microphone / Accessibility) are
	     keyed to it too — changing it would strand 0.1.x users and reset every permission. Plumbing only;
	     nothing user-visible shows it. -->
	<key>CFBundleIdentifier</key>
	<string>io.github.sethmed7.voz</string>
	<key>CFBundleName</key>
	<string>warble</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.7.0</string>
	<key>CFBundleVersion</key>
	<string>0.7.0</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<key>LSUIElement</key>
	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>warble records only while you hold the dictation hotkey, transcribes it on-device, and never saves the audio.</string>
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Read Aloud with warble</string>
			</dict>
			<key>NSMessage</key>
			<string>readAloud</string>
			<key>NSPortName</key>
			<string>warble</string>
			<key>NSSendTypes</key>
			<array>
				<string>NSStringPboardType</string>
			</array>
		</dict>
	</array>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>warble can fall back to Apple's on-device speech recognizer; recognition stays on your Mac.</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/SethMed7/warble/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>ctuyDA3r2a+kq9gpkkNu9ciA2YEAZ8ImMxIJ9ndtMLc=</string>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
